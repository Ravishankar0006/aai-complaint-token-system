# Copy this file to .env (for local development) and fill in the values
# from your Supabase project: Project Settings -> API.
#
# On Render, do NOT upload a .env file — instead add these same two
# variables under your service's "Environment" tab in the dashboard.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
